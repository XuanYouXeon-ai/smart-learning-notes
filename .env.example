# Smart Learning Notes - Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smart_learning_notes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MinIO / RustFS (S3 Compatible Storage)
APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=your_access_key_here
APP_STORAGE_SECRET_KEY=your_secret_key_here
APP_STORAGE_BUCKET=smart-learning-notes
APP_STORAGE_REGION=us-east-1

# AI - Alibaba Cloud DashScope (OpenAI Compatible)
AI_DASHSCOPE_API_KEY=your_dashscope_api_key_here
AI_MODEL=qwen-plus

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:80
